# ============================================================================
# Ringo — Environment Variables Template
# Copy to .env.local and fill in real values. Never commit real values.
# ============================================================================

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- App ----------
NEXT_PUBLIC_APP_URL=https://www.useringo.ai

# ---------- Retell AI (voice agent) ----------
# Get from https://dashboard.retellai.com → API Keys
RETELL_API_KEY=
# Webhook secret — set when you configure the agent's webhook in Retell dashboard
RETELL_WEBHOOK_SECRET=
# Agent ID for the public "Try Ringo" demo on the website (create a demo agent in Retell)
RETELL_DEMO_AGENT_ID=
# E.164 number Ringo dials FROM when the website demo uses "call my phone" mode
RETELL_DEMO_FROM_NUMBER=+12098212457

# ---------- Google Places (website live demo) ----------
# Enable Places API (New) + Maps JavaScript API + Geocoding API at console.cloud.google.com
# Restrict the key to your domain(s) before going live.
GOOGLE_PLACES_API_KEY=

# ---------- Demo lead alerts ----------
# Slack incoming webhook URL — gets pinged when a demo call completes so you can follow up warm
DEMO_ALERT_SLACK_WEBHOOK=
# Email address to copy on demo lead alerts (optional — uses Resend if configured)
DEMO_ALERT_EMAIL=

# ---------- Twilio (SMS + phone numbers) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---------- GoHighLevel (SMS primary, Twilio fallback) ----------
GHL_API_KEY=
GHL_LOCATION_ID=

# ---------- Stripe (billing) ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# ---------- Resend (transactional email) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@useringo.ai

# ---------- Square POS ----------
SQUARE_APP_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=

# ---------- Clover POS ----------
CLOVER_APP_ID=EJME49015T3CR
CLOVER_APP_SECRET=

# ---------- Toast POS ----------
TOAST_API_KEY=
TOAST_RESTAURANT_GUID=
TOAST_ENVIRONMENT=sandbox

# ---------- SpotOn POS ----------
SPOTON_API_KEY=
SPOTON_LOCATION_ID=
